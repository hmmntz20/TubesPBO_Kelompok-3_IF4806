# ──────────────────────────────────────────────────────────────────────────
# Telkom Route Finder — Frontend env template
#
# Cara pakai:
#   1. Salin file ini menjadi `.env` (sudah diabaikan oleh .gitignore root).
#   2. Isi nilainya dengan kredensial Anda.
#   3. Jalankan `npx expo start` (atau `expo run:android` / `run:ios`).
#
# Penamaan: prefix `EXPO_PUBLIC_` membuat var dapat dibaca di runtime
# JS bundle. JANGAN tempatkan secret yang TIDAK boleh masuk bundle di sini.
# ──────────────────────────────────────────────────────────────────────────

# Google Maps API key untuk Android (di-restrict per package name "pbo.telkomroute" di Cloud Console).
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# Google Maps API key untuk iOS (di-restrict per bundle id "pbo.telkomroute" di Cloud Console).
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=

# Base URL backend Spring Boot.
# - Android emulator (AVD)     : http://10.0.2.2:8080
# - iOS simulator              : http://localhost:8080
# - Perangkat fisik di LAN     : http://<ip-host>:8080
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# ── Supabase ──
# URL project: https://<project-ref>.supabase.co (dari Supabase dashboard).
EXPO_PUBLIC_SUPABASE_URL=

# Anon key — JWT publik untuk role 'anon'. Aman dibundel ke aplikasi mobile
# karena Row-Level Security (RLS) di Supabase membatasi akses.
# Ambil di Supabase dashboard → Project Settings → API → "Project API keys" → "anon / public".
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# (Opsional) Scheme untuk redirect OAuth ke aplikasi setelah Google login.
# Default mengikuti scheme di app.json. Set hanya jika butuh kustom.
# EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=telkomroute
