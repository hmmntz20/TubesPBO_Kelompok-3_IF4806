# ──────────────────────────────────────────────────────────────────────────
# backend/.env.example
#
# Salin file ini menjadi .env lalu isi nilainya.
# File .env sudah masuk .gitignore — JANGAN commit yang berisi rahasia.
#
# Cara pakai (pilih salah satu):
#   A) source .env && ./mvnw spring-boot:run
#   B) Pakai plugin dotenv di IDE (IntelliJ EnvFile, VS Code dotenv)
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres atau Postgres lokal) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telkomroute
DB_USER=postgres
DB_PASSWORD=postgres

# ── Supabase Auth ──
# Ambil di: Supabase dashboard → Project Settings → API → "JWT Secret"
SUPABASE_JWT_SECRET=
# Project ref (bagian subdomain dari URL Supabase Anda, misal: abcdefghijk)
SUPABASE_PROJECT_REF=
